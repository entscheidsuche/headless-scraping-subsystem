# Copy to /etc/headless-scraping-subsystem.env on the server, or to .env
# locally for development. NEVER commit a populated copy.

# Bind only to loopback; nginx terminates TLS and forwards.
BIND_HOST=127.0.0.1
BIND_PORT=8088

# Production MUST set this. Generate with:  openssl rand -hex 32
BEARER_TOKEN=

# How many concurrent challenges to solve. Each context costs ~150-250 MB.
BROWSER_POOL_SIZE=2

# Per-challenge ceiling (seconds).
CHALLENGE_TIMEOUT_S=60

# How long the browser waits per delegated fetch.
FEED_WAIT_TIMEOUT_S=45

HEADLESS=true
LOG_LEVEL=INFO

# Hard cap on delegated fetches per challenge (defence in depth).
MAX_FETCHES_PER_CHALLENGE=50
